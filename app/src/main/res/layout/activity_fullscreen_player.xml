<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000" />

    <!-- 顶部控制栏 -->
    <LinearLayout
        android:id="@+id/topControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#80000000"
        android:visibility="visible">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/button_transparent_background"
            android:scaleType="centerInside"
            android:contentDescription="返回" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="视频标题"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- 底部控制栏 -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#80000000"
        android:visibility="visible">

        <!-- 进度条 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="12sp"
                android:textColor="#FFFFFFFF" />

            <SeekBar
                android:id="@+id/seekBarProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:progressTint="#FF4CAF50"
                android:thumbTint="#FF4CAF50" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="12sp"
                android:textColor="#FFFFFFFF" />

        </LinearLayout>

        <!-- 控制按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_rewind"
                android:background="@drawable/button_transparent_background"
                android:scaleType="centerInside"
                android:layout_marginEnd="24dp"
                android:contentDescription="快退" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/button_transparent_background"
                android:scaleType="centerInside"
                android:contentDescription="播放" />

            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_forward"
                android:background="@drawable/button_transparent_background"
                android:scaleType="centerInside"
                android:layout_marginStart="24dp"
                android:contentDescription="快进" />

        </LinearLayout>

    </LinearLayout>

    <!-- 亮度提示 -->
    <LinearLayout
        android:id="@+id/brightnessIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="40dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#AA000000"
        android:padding="16dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_brightness"
            android:contentDescription="亮度" />

        <TextView
            android:id="@+id/tvBrightnessValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textSize="14sp"
            android:textColor="#FFFFFFFF"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- 音量提示 -->
    <LinearLayout
        android:id="@+id/volumeIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="40dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#AA000000"
        android:padding="16dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_volume_up"
            android:contentDescription="音量" />

        <TextView
            android:id="@+id/tvVolumeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textSize="14sp"
            android:textColor="#FFFFFFFF"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</FrameLayout>